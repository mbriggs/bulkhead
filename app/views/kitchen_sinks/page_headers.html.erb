<%= page_header "Page Headers" do |h| %>
  <%= h.breadcrumb "Kitchen Sink", kitchen_sink_path %>
<% end %>

<%= page(columns: false) do %>
  <%# ── Minimal ── %>
  <div class="<%= card_classes %>">
    <%= card_header("Minimal", "Title only — no breadcrumbs, actions, or metadata. Used for top-level index pages.") %>

    <div class="p-5"><%= page_header "Problems", separator: false %></div>
  </div>

  <%# ── With Breadcrumbs ── %>
  <div class="<%= card_classes %>">
    <%= card_header("With Breadcrumbs", "Breadcrumbs orient the user within a hierarchy. Pass h.breadcrumb with a label and URL.") %>

    <div class="p-5">
      <%= page_header "Onboarding Flow", separator: false do |h| %>
        <% h.breadcrumb "Problems", "#" %>
      <% end %>
    </div>
  </div>

  <%# ── Primary Action ── %>
  <div class="<%= card_classes %>">
    <%= card_header("Primary Action", "The main CTA for the page. Always visible, including on mobile. Renders as a primary button.") %>

    <div class="p-5">
      <%= page_header "Problems", separator: false do |h| %>
        <% h.primary_action "New Problem", "#" %>
      <% end %>
    </div>
  </div>

  <%# ── Secondary Actions ── %>
  <div class="<%= card_classes %>">
    <%= card_header("Secondary Actions", "Supporting actions render as secondary buttons. Hidden on mobile — they collapse into a \"More\" menu.") %>

    <div class="p-5">
      <%= page_header "Onboarding Flow", separator: false do |h| %>
        <% h.breadcrumb "Problems", "#" %>
        <% h.action "Export", "#" %>
        <% h.action "Duplicate", "#" %>
        <% h.primary_action "Start Review", "#", method: :post %>
      <% end %>
    </div>
  </div>

  <%# ── With Metadata ── %>
  <div class="<%= card_classes %>">
    <%= card_header("With Metadata", "Use h.datem to add icon+text metadata below the title. Good for timestamps, status, and ownership.") %>

    <div class="p-5">
      <%= page_header "Onboarding Flow", separator: false do |h| %>
        <% h.breadcrumb "Problems", "#" %>
        <% h.datem :calendar, "Created 3 days ago" %>
        <% h.datem :user, "Alice Johnson" %>
        <% h.primary_action "Start Review", "#", method: :post %>
      <% end %>
    </div>
  </div>

  <%# ── Dropdown Actions ── %>
  <div class="<%= card_classes %>">
    <%= card_header("Dropdown Actions", "Group related actions under a dropdown button. Supports links, dividers, and modal triggers.") %>

    <div class="p-5">
      <%= page_header "Onboarding Flow", separator: false do |h| %>
        <% h.breadcrumb "Problems", "#" %>
        <% h.primary_action "Start Review", "#", method: :post %>

        <% h.dropdown_action "More", [
          { name: "Export as PDF", url: "#" },
          { name: "Duplicate", url: "#" },
          { divider: true },
          { name: "Archive", url: "#" },
        ] %>
      <% end %>
    </div>
  </div>

  <%# ── Full Kitchen Sink ── %>
  <div class="<%= card_classes %>">
    <%= card_header("Everything Together", "Breadcrumbs, metadata, secondary actions, primary action, and a dropdown — all at once.") %>

    <div class="p-5">
      <%= page_header "Onboarding Flow", separator: false do |h| %>
        <% h.breadcrumb "Problems", "#" %>
        <% h.datem :calendar, "Created 3 days ago" %>
        <% h.datem :clock, "Updated 2 hours ago" %>
        <% h.datem :user, "Alice Johnson" %>
        <% h.action "Export", "#" %>
        <% h.primary_action "Start Review", "#", method: :post %>

        <% h.dropdown_action "More", [
          { name: "Duplicate", url: "#" },
          { name: "Move to Draft", url: "#" },
          { divider: true },
          { name: "Delete", url: "#" },
        ] %>
      <% end %>
    </div>
  </div>
<% end %>
