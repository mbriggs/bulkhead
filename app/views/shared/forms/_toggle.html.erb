<%
  # Local variables expected:
  # - form: the form builder object (nil for standalone)
  # - method: the attribute name
  # - label: the label text
  # - caption: optional caption text
  # - hint: optional hint text
  # - size: optional size class
  # - data: optional data attributes (for standalone)
  # - value: optional initial value (for standalone)
  # - object_name: object name (for standalone when form is nil)
  # - field_id: field id (for standalone when form is nil)

  if form
    field_id = "#{form.object_name}_#{method}"
    checked = form.object&.respond_to?(method) && form.object.public_send(method)
  else
    checked = value
  end

  size_class = size || "@sm:col-span-6"
  data ||= {}
%>

<div class="<%= size_class %>">
  <div class="flex items-start" data-controller="toggle">
    <% if form %>
      <%= form.check_box! method,
          class: "sr-only",
          id: field_id,
          data: {
            toggle_target: "checkbox",
            action: "change->toggle#update"
          }.merge(data) %>
    <% else %>
      <%= check_box_tag method,
          "1",
          value,
          class: "sr-only",
          id: field_id,
          data: {
            toggle_target: "checkbox",
            action: "change->toggle#update"
          }.merge(data) %>
    <% end %>

    <button type="button"
            role="switch"
            aria-checked="<%= checked ? "true" : "false" %>"
            class="relative inline-flex h-5 w-9 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent <%= checked ? "bg-primary-600 dark:bg-primary-500" : "bg-zinc-200 dark:bg-zinc-700" %> shadow-sm transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-primary-600 dark:focus:ring-primary-500 focus:ring-offset-2 dark:focus:ring-offset-zinc-900"
            data-toggle-target="switch"
            data-action="click->toggle#toggle">
      <span class="pointer-events-none relative inline-block h-4 w-4 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out <%= checked ? "translate-x-4" : "translate-x-0" %>"
            data-toggle-target="slider">
      </span>
    </button>

    <div class="ml-3">
      <label for="<%= field_id %>" class="text-sm font-medium text-zinc-900 dark:text-zinc-100 cursor-pointer">
        <%= label %>
      </label>
      <% if caption.present? %>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 cursor-pointer"><%= caption %></p>
      <% end %>
    </div>
  </div>
  <% if hint.present? %>
    <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400"><%= hint %></p>
  <% end %>
</div>
