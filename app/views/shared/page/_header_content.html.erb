<div class="@lg:flex @lg:items-center @lg:justify-between px-4 @sm:px-6 @lg:px-8">
  <div class="min-w-0 flex-1">
    <%= breadcrumbs %>

    <h2
      class="
        mt-2 text-2xl/7 font-bold text-zinc-900 dark:text-zinc-100
        @sm:truncate @sm:text-3xl @sm:tracking-tight
      "
    >
      <%= title %>
    </h2>

    <div class="mt-1 flex flex-col @sm:mt-0 @sm:flex-row @sm:flex-wrap @sm:gap-6">
      <% data.each do |icon, text| %>
        <%= page_datem(icon, text) %>
      <% end %>
    </div>
  </div>

  <%= render "shared/page/header_actions",
    actions: actions,
    primary_actions: primary_actions,
    dropdown_actions: dropdown_actions,
    custom_entries: custom_entries %>
</div>
