<div class="<%= classes %>">
  <% items.each_with_index do |item, idx| %>
    <% border = idx < items.size - 1 ? "border-b border-zinc-200 dark:border-zinc-700" : "" %>
    <% row_classes = "group flex items-center w-full px-4 py-3 hover:bg-zinc-50 dark:hover:bg-zinc-700/50 transition-colors text-left" %>

    <%# Shared item body: image + title/metas + badges + chevron %>
    <% item_body = capture do %>
      <% if item[:image] %>
        <div class="flex-shrink-0 mr-3">
          <% if item[:image][:url] %>
            <div class="w-10 h-10 overflow-hidden rounded-md bg-zinc-100 dark:bg-zinc-700">
              <%= image_tag item[:image][:url],
                  class: "w-full h-full object-cover",
                  alt: item[:image][:alt] %>
            </div>
          <% else %>
            <div class="w-10 h-10 bg-zinc-100 dark:bg-zinc-700 rounded-md flex items-center justify-center">
              <% icon_name = item[:image][:fallback_icon] || :photograph %>
              <%= icon_by_name(icon_name, classes: "w-5 h-5 text-zinc-400 dark:text-zinc-500") %>
            </div>
          <% end %>
        </div>
      <% end %>

      <div class="flex-1 min-w-0">
        <% if item[:title] %>
          <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100 truncate <%= item[:title][:classes] %>">
            <%= item[:title][:text] %>
          </p>
        <% end %>

        <% if item[:metas].present? %>
          <div class="flex items-center gap-2 mt-0.5">
            <% item[:metas].each do |meta| %>
              <span class="flex items-center text-xs text-zinc-500 dark:text-zinc-400 <%= meta[:classes] %>">
                <% if meta[:icon] %>
                  <%= icon_by_name(meta[:icon], classes: "w-3.5 h-3.5 mr-1 text-zinc-400 dark:text-zinc-500") %>
                <% end %>
                <%= meta[:text] %>
              </span>
            <% end %>
          </div>
        <% end %>
      </div>

      <% if item[:badges].present? %>
        <div class="flex items-center gap-2 ml-3">
          <% item[:badges].each do |badge| %>
            <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset <%= badge_color_classes(badge[:type]) %>">
              <% if badge[:icon] %>
                <%= icon_by_name(badge[:icon], classes: "w-3 h-3 mr-1") %>
              <% end %>
              <%= badge[:text] %>
            </span>
          <% end %>
        </div>
      <% end %>

      <div class="flex-shrink-0 ml-3">
        <%= icon(:chevron_right, classes: "w-4 h-4 text-zinc-300 dark:text-zinc-600 group-hover:text-zinc-400 dark:group-hover:text-zinc-500 transition-colors") %>
      </div>
    <% end %>

    <% if item[:modal] %>
      <%= modal_wrapper(tag_name: :div, classes: border) do %>
        <%= modal_open_button(options: { class: row_classes }) do %>
          <%= item_body %>
        <% end %>

        <% m = item[:modal] %>
        <% if m[:partial] %>
          <%= modal_dialog(id: m[:id], title: m[:title], size: m[:size] || :md, header_actions: m[:header_actions], partial: m[:partial], locals: m[:locals] || {}) %>
        <% elsif m[:block] %>
          <%= modal_dialog(id: m[:id], title: m[:title], size: m[:size] || :md, header_actions: m[:header_actions]) do %>
            <%= capture(&m[:block]) %>
          <% end %>
        <% end %>
      <% end %>
    <% else %>
      <%= link_to item[:path], class: "#{row_classes} #{border}" do %>
        <%= item_body %>
      <% end %>
    <% end %>
  <% end %>
</div>
