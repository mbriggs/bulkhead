<div class="<%= classes %>">
  <table class="min-w-full divide-y divide-zinc-200 dark:divide-zinc-700">
    <% if headers.any? { |h| h[:title].present? } %>
      <thead>
        <tr>
          <% headers.each do |h| %>
            <th scope="col" class="<%= h[:classes] %> px-3 py-3 text-left text-xs font-medium uppercase tracking-wide text-zinc-500 dark:text-zinc-400">
              <%= h[:title] %>
            </th>
          <% end %>
        </tr>
      </thead>
    <% end %>
    <%= tag.tbody(**tbody_attrs) do %>
      <%= body %>
      <% if pager %>
        <%= table_paginate pager, columns: headers.length %>
      <% end %>
    <% end %>
  </table>
</div>
